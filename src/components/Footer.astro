---
import LinkedInIcon from "./icons/LinkedIn.astro";
import GithubIcon from "./icons/Github.astro";
import GmailIcon from "./icons/Gmail.astro";
---

<footer class="bg-purple-200/5 rounded-xl shadow m-4 mt-12 border border-white/10">
  <div class="w-full mx-auto max-w-screen-xl p-4 md:p-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-col gap-1">
      <span class="text-base text-yellow-100/90 font-semibold">Guido Juliano Ubaldi</span>
      <span class="text-sm text-white/70">Web/Mobile Developer</span>
    </div>

    <ul class="flex flex-wrap items-center gap-4">
      <li>
        <a
          href="https://www.linkedin.com/in/guidojuliano/"
          target="_blank"
          rel="noopener"
          aria-label="LinkedIn"
          class="inline-flex items-center justify-center text-[#7dd3fc] hover:text-[#bae6fd] transition hover:scale-110"
        >
          <LinkedInIcon class="size-5" aria-hidden="true" />
        </a>
      </li>
      <li>
        <a
          href="https://github.com/guidojuliano"
          target="_blank"
          rel="noopener"
          aria-label="GitHub"
          class="inline-flex items-center justify-center text-[#a5b4fc] hover:text-[#c7d2fe] transition hover:scale-110"
        >
          <GithubIcon class="size-5" aria-hidden="true" />
        </a>
      </li>
      <li>
        <a
          href="mailto:guidojulianou@gmail.com"
          aria-label="Gmail"
          class="inline-flex items-center justify-center text-[#fca5a5] hover:text-[#fecaca] transition hover:scale-110"
        >
          <GmailIcon class="size-5" aria-hidden="true" />
        </a>
      </li>
    </ul>
  </div>
</footer>
