---
import { Image } from "astro:assets";
import TechBadge from "./TechBadge.astro";
import GithubIcon from "./icons/Github.astro";
import quixImage from "../media/images/quix.jpg";
import arkanoidImage from "../media/images/arkanoid.jpg";
import restauranteImage from "../media/images/restaurante.png";
import guidopaloozaImage from "../media/images/guidopalooza.png";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const PROJECTS = [
  {
    title: t("projects.project1"),
    description: t("projects.description1"),
    link: "https://quix-next.vercel.app",
    github: "https://github.com/guidojuliano/quix-next",
    image: quixImage,
    tags: [
      "TypeScript",
      "Sass",
      "Next.js",
      "Shopify",
      "Figma",
      "Postman",
      "GraphQL",
    ],
  },
  {
    title: "Arkanoid",
    description: t("projects.description2"),
    link: "https://arkanoid-js.vercel.app/",
    github: "https://github.com/guidojuliano/ArkanoidJS",
    image: arkanoidImage,
    tags: ["JavaScript", "CSS", "HTML"],
  },
  {
    title: "Pizzeria Ubaldi",
    description: t("projects.description3"),
    link: "https://restaurante-landing-three.vercel.app/",
    github: "https://github.com/guidojuliano/restaurante-landing",
    image: restauranteImage,
    tags: ["JavaScript", "Astro", "HTML", "TailwindCSS"],
  },
  {
    title: t("projects.project4"),
    description: t("projects.description4"),
    link: "https://guidopalooza.vercel.app/",
    github: "https://github.com/guidojuliano/guidopalooza",
    image: guidopaloozaImage,
    tags: ["Next.js", "Motion", "Shadcn", "TypeScript"],
  },
];

const TECH_ICON_MAP: Record<string, { icon?: string; useReactIcon?: boolean }> = {
  TypeScript: { icon: "https://svgl.app/library/typescript.svg" },
  Sass: { icon: "https://svgl.app/library/sass.svg" },
  "Next.js": { icon: "https://svgl.app/library/nextjs_icon_dark.svg" },
  Shopify: { icon: "https://svgl.app/library/shopify.svg" },
  Figma: { icon: "https://svgl.app/library/figma.svg" },
  Postman: { icon: "https://svgl.app/library/postman.svg" },
  GraphQL: { icon: "https://svgl.app/library/graphql.svg" },
  JavaScript: { icon: "https://svgl.app/library/javascript.svg" },
  CSS: { icon: "https://svgl.app/library/css_old.svg" },
  HTML: { icon: "https://svgl.app/library/html5.svg" },
  Astro: { icon: "https://svgl.app/library/astro-icon-dark.svg" },
  TailwindCSS: { icon: "https://svgl.app/library/tailwindcss.svg" },
  Motion: { icon: "https://svgl.app/library/framer_motion.svg" },
  Shadcn: { icon: "https://svgl.app/library/shadcn-ui_dark.svg" },
  React: { useReactIcon: true },
  "React Native": { useReactIcon: true },
  Flutter: { icon: "https://svgl.app/library/flutter.svg" },
  Supabase: { icon: "https://svgl.app/library/supabase.svg" },
  "Node.js": { icon: "https://svgl.app/library/nodejs.svg" },
  Fastify: { icon: "https://svgl.app/library/fastify_dark.svg" },
};
---

{
  PROJECTS.map((project) => (
    <article class="py-5">
      <h3 class="text-2xl font-semibold text-yellow-200/90">{project.title}</h3>
      <p class="text-fuchsia-200">{project.description}</p>
      <a href={project.link} target="_blank" rel="noopener">
        <Image
          class="my-3 rounded shadow-2xl shadow-white/10"
          src={project.image}
          alt="Screenshot of project"
        />
      </a>

      <ul class="flex py-2 flex-wrap gap-1">
        {project.tags.map((tag) => (
          <li>
            <TechBadge
              label={tag}
              icon={TECH_ICON_MAP[tag]?.icon}
              useReactIcon={Boolean(TECH_ICON_MAP[tag]?.useReactIcon)}
            />
          </li>
        ))}
      </ul>
      <a href={project.github} target="_blank" rel="noopener">
        <button
          type="button"
          class="mt-3 text-blue-100 bg-blue-200/20 hover:bg-fuchsia-800 transition focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center inline-flex items-center me-2 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800 gap-x-2"
        >
          <GithubIcon class="size-4" />
          {t("projects.button")}
        </button>
      </a>
    </article>
  ))
}
