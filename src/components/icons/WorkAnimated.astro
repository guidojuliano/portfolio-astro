<svg
  {...Astro.props}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  fill="none"
  aria-hidden="true"
>
  <rect x="10" y="22" width="44" height="28" rx="6" fill="currentColor" opacity="0.2"></rect>
  <rect x="22" y="14" width="20" height="10" rx="4" stroke="currentColor" stroke-width="2"></rect>
  <path d="M10 34c6 3 12 4.5 22 4.5S48 37 54 34" stroke="currentColor" stroke-width="2"></path>
  <rect x="29" y="31" width="6" height="4" rx="1" fill="#fde68a"></rect>

  <g class="briefcase-bob">
    <rect x="12" y="24" width="40" height="24" rx="5" stroke="currentColor" stroke-width="1.8"></rect>
  </g>

  <circle class="pulse pulse-1" cx="49" cy="18" r="2.2" fill="#93c5fd"></circle>
  <circle class="pulse pulse-2" cx="53" cy="14" r="1.4" fill="#c4b5fd"></circle>
</svg>

<style>
  .briefcase-bob {
    transform-origin: center;
    animation: work-bob 2.1s ease-in-out infinite;
  }

  .pulse {
    transform-origin: center;
    animation: work-pulse 1.8s ease-out infinite;
    opacity: 0;
  }

  .pulse-2 {
    animation-delay: 0.45s;
  }

  @keyframes work-bob {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-1.5px);
    }
  }

  @keyframes work-pulse {
    0% {
      opacity: 0;
      transform: scale(0.6);
    }
    35% {
      opacity: 0.85;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1.7);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .briefcase-bob,
    .pulse {
      animation: none !important;
    }
  }
</style>
