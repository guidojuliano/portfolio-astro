---
import ReactIcon from "./icons/React.astro";

interface Props {
  label: string;
  icon?: string;
  useReactIcon?: boolean;
}

const { label, icon = "", useReactIcon = false } = Astro.props as Props;
---

<span class="inline-flex items-center gap-2 rounded-md border border-white/20 bg-white/10 backdrop-blur-sm px-2.5 py-1 text-xs font-semibold text-blue-100 shadow-sm shadow-black/10">
  <span class="flex h-5 w-5 items-center justify-center rounded bg-black/35 border border-white/10">
    {useReactIcon ? (
      <ReactIcon class="h-3.5 w-3.5" />
    ) : (
      <>
        <img
          src={icon}
          alt={`${label} logo`}
          class="h-3.5 w-3.5 object-contain"
          loading="lazy"
          decoding="async"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-flex';"
        />
        <span class="hidden h-3.5 w-3.5 items-center justify-center text-[8px] font-bold text-white/90">
          {label.slice(0, 2).toUpperCase()}
        </span>
      </>
    )}
  </span>
  {label}
</span>
