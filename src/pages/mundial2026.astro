    if (!gridEl) return;
    
    const searchVal = (document.getElementById('filter-search') as HTMLInputElement)?.value.toLowerCase() || '';
    const stageVal = (document.getElementById('filter-stage') as HTMLSelectElement)?.value || 'all';
    const groupVal = (document.getElementById('filter-group') as HTMLSelectElement)?.value || 'all';
    const checkLive = (document.getElementById('filter-check-live') as HTMLInputElement)?.checked || false;
    const checkFavs = (document.getElementById('filter-check-favorites') as HTMLInputElement)?.checked || false;
    
    const filtered = matches.filter(m => {
      const homeName = m.home_team_id === "0" ? (m.home_team_label || '') : getTeamName(m.home_team_name_en);
      const awayName = m.away_team_id === "0" ? (m.away_team_label || '') : getTeamName(m.away_team_name_en);
      const searchMatch = homeName.toLowerCase().includes(searchVal) || awayName.toLowerCase().includes(searchVal);
      
      const stageMatch = stageVal === 'all' || m.type === stageVal;
      const groupMatch = groupVal === 'all' || (m.type === 'group' && m.group === groupVal);
      const liveMatch = !checkLive || m.finished === "TRUE" || m.time_elapsed !== "notstarted";
      
      const favoriteTeams = ["Argentina", "México", "United States", "Brazil", "Colombia"];
      const favsMatch = !checkFavs || 
                        favoriteTeams.includes(m.home_team_name_en) || 
                        favoriteTeams.includes(m.away_team_name_en);
                        
      return searchMatch && stageMatch && groupMatch && liveMatch && favsMatch;
    });

    const sorted = [...filtered].sort((a, b) => {
      const aLive = a.finished === "FALSE" && a.time_elapsed !== "notstarted" ? 1 : 0;
      const bLive = b.finished === "FALSE" && b.time_elapsed !== "notstarted" ? 1 : 0;
      if (aLive !== bLive) return bLive - aLive;
      
      const aDate = getMatchDate(a.local_date, a.stadium_id).getTime();
      const bDate = getMatchDate(b.local_date, b.stadium_id).getTime();
      return aDate - bDate;
    });

