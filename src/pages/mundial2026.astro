---

<Layout title="Mundial 2026 - Fixture & Cuenta Regresiva | Guido Juliano">
  <!-- Datos para el Script del Cliente -->
  <div 
    id="app-data" 
    class="hidden" 
    data-matches={JSON.stringify(matchesData.games)} 
    data-teams={JSON.stringify(teamsData.teams)} 
    data-stadiums={JSON.stringify(stadiumsData.stadiums)}
    data-translations={JSON.stringify(teamTranslations)}
    data-stages={JSON.stringify(stageTranslations)}
    data-stadium-info={JSON.stringify(stadiumTimezones)}
  ></div>

  <main class="max-w-6xl mx-auto px-4 py-28 flex flex-col gap-8 text-slate-100 font-sans">
    
    <!-- Título Principal y Estado API -->
    <section class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 border-b border-slate-800 pb-6">
      <div>
        <div class="flex items-center gap-2">
          <span class="text-3xl">⚽</span>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-white font-display">
            MUNDIAL <span class="bg-gradient-to-r from-amber-400 via-yellow-200 to-emerald-400 bg-clip-text text-transparent">FIFA 2026</span>
          </h1>
        </div>
        <p class="text-xs text-slate-400 uppercase tracking-widest font-semibold mt-1">
          Fixture Interactivo, Horario Local & Marcadores en Vivo
        </p>
      </div>

      <div class="flex items-center gap-4">
        <!-- Reloj local del usuario -->
        <div class="text-left md:text-right">
          <p class="text-[10px] text-slate-500 font-bold uppercase tracking-wider">Tu Hora Local</p>
          <p id="user-local-clock" class="text-sm font-semibold tracking-widest text-slate-200">--:--:--</p>
        </div>
        
        <!-- Estado de la API -->
        <div id="api-status" class="flex items-center gap-2 px-3 py-1.5 rounded-full text-[10px] font-bold uppercase bg-slate-900 border border-slate-800">
          <span id="api-status-dot" class="w-2.5 h-2.5 rounded-full bg-yellow-500 animate-pulse"></span>
          <span id="api-status-text" class="text-slate-400">Conectando...</span>
        </div>
      </div>
    </section>

    <!-- HERO: Próximo partido o Partido en Vivo -->
    <section id="hero-match" class="bg-slate-950/40 backdrop-blur-md border border-slate-800 rounded-3xl p-6 md:p-8 shadow-2xl relative overflow-hidden transition-all duration-300">
      <h2 class="sr-only">Partido Destacado</h2>
      
      <!-- Fondo decorativo -->
      <div class="absolute inset-0 bg-gradient-to-r from-emerald-950/10 to-amber-950/5 pointer-events-none"></div>

      <!-- SKELETON LOADER -->
      <div id="hero-skeleton" class="animate-pulse flex flex-col gap-6 relative z-10">
        <div class="flex justify-between items-center">
          <div class="h-4 w-32 bg-slate-900 rounded-full"></div>
          <div class="h-3.5 w-40 bg-slate-900 rounded"></div>
        </div>
        <div class="flex flex-col md:flex-row items-center justify-around gap-8 py-4">
          <div class="flex flex-col items-center gap-3 w-full md:w-1/3 text-center">
            <div class="w-24 h-16 bg-slate-900/60 rounded-xl mx-auto"></div>
            <div class="h-5 w-28 bg-slate-900/60 rounded mx-auto mt-2"></div>
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="h-3.5 w-8 bg-slate-900/60 rounded"></div>
            <div class="h-10 w-24 bg-slate-900/60 rounded-lg"></div>
          </div>
          <div class="flex flex-col items-center gap-3 w-full md:w-1/3 text-center">
            <div class="w-24 h-16 bg-slate-900/60 rounded-xl mx-auto"></div>
            <div class="h-5 w-28 bg-slate-900/60 rounded mx-auto mt-2"></div>
          </div>
        </div>
        <div class="border-t border-slate-900 pt-6 flex flex-col md:flex-row justify-between items-center gap-6">
          <div class="h-6 w-48 bg-slate-900/60 rounded-lg"></div>
          <div class="h-4 w-40 bg-slate-900/60 rounded"></div>
        </div>
      </div>

      <!-- CONTENIDO REAL (Oculto inicialmente) -->
      <div id="hero-content" class="hidden flex flex-col gap-0 relative z-10">
        <!-- Fila superior -->
        <div class="flex justify-between items-center flex-wrap gap-2">
          <span id="hero-tag" class="text-[10px] uppercase font-extrabold tracking-wider px-3 py-1 rounded-full border border-slate-800 bg-slate-900 text-slate-300">Cargando...</span>
          <span id="hero-stadium" class="text-xs text-slate-400 font-medium">📍 --</span>
        </div>

        <!-- Versus -->
        <div class="flex flex-col md:flex-row items-center justify-around gap-8 py-8">
          <!-- Home Team -->
          <div class="flex flex-col items-center gap-3 w-full md:w-1/3 text-center">
            <img id="hero-home-flag" src="https://flagcdn.com/w80/un.png" alt="" class="w-24 h-16 object-cover rounded-xl shadow-lg border border-slate-800 transition-transform duration-300 hover:scale-105" />
            <div id="hero-home-name" class="text-xl md:text-2xl font-black text-white font-display">--</div>
          </div>

          <!-- Marcador central -->
          <div class="flex flex-col items-center justify-center gap-3">
            <div id="hero-live-time" class="hidden px-3 py-1 rounded-md bg-red-600 text-white text-[10px] font-black tracking-widest uppercase animate-pulse">
              --
            </div>
            <div class="flex items-center gap-6">
              <span id="hero-home-score" class="text-5xl md:text-7xl font-black font-display text-white tracking-tight">0</span>
              <span id="hero-score-divider" class="text-2xl font-bold text-slate-600">-</span>
              <span id="hero-away-score" class="text-5xl md:text-7xl font-black font-display text-white tracking-tight">0</span>
              <span id="hero-score-vs" class="text-2xl font-extrabold text-slate-500 font-display hidden">VS</span>
            </div>
            <span id="hero-score-label-vs" class="text-[10px] tracking-[0.2em] font-extrabold text-slate-400 uppercase">VS</span>
          </div>

          <!-- Away Team -->
          <div class="flex flex-col items-center gap-3 w-full md:w-1/3 text-center">
            <img id="hero-away-flag" src="https://flagcdn.com/w80/un.png" alt="" class="w-24 h-16 object-cover rounded-xl shadow-lg border border-slate-800 transition-transform duration-300 hover:scale-105" />
            <div id="hero-away-name" class="text-xl md:text-2xl font-black text-white font-display">--</div>
          </div>
        </div>

        <!-- Goleadores del Hero -->
        <div id="hero-scorers" class="hidden flex justify-between items-start text-xs text-slate-400 px-6 py-3 border-t border-slate-800/40 bg-slate-950/20 rounded-2xl gap-8 -mt-4 mb-6">
          <div id="hero-home-scorers" class="w-1/2 text-left flex items-start gap-1.5 min-w-0 text-slate-300">
            <!-- Dinámico -->
          </div>
          <div id="hero-away-scorers" class="w-1/2 text-right flex items-start justify-end gap-1.5 min-w-0 text-slate-300">
            <!-- Dinámico -->
          </div>
        </div>

        <!-- Fila inferior (Cuenta regresiva y horarios) -->
        <div class="border-t border-slate-800/80 pt-6 flex flex-col md:flex-row justify-between items-center gap-6">
          <!-- Cuenta regresiva -->
          <div id="hero-countdown-container" class="flex flex-col gap-2 w-full md:w-auto items-center md:items-start">
            <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">Cuenta Regresiva</span>
            <div class="flex gap-2">
              <div class="flex flex-col items-center justify-center bg-slate-900/80 border border-slate-800 rounded-xl p-2.5 min-w-[64px]">
                <span id="cd-days" class="text-2xl font-black text-white font-display leading-none">00</span>
                <span class="text-[8px] uppercase font-bold text-slate-500 tracking-wider mt-1.5">Días</span>
              </div>
              <div class="flex flex-col items-center justify-center bg-slate-900/80 border border-slate-800 rounded-xl p-2.5 min-w-[64px]">
                <span id="cd-hours" class="text-2xl font-black text-white font-display leading-none">00</span>
                <span class="text-[8px] uppercase font-bold text-slate-500 tracking-wider mt-1.5">Horas</span>
              </div>
              <div class="flex flex-col items-center justify-center bg-slate-900/80 border border-slate-800 rounded-xl p-2.5 min-w-[64px]">
                <span id="cd-minutes" class="text-2xl font-black text-white font-display leading-none">00</span>
                <span class="text-[8px] uppercase font-bold text-slate-500 tracking-wider mt-1.5">Min</span>
              </div>
              <div class="flex flex-col items-center justify-center bg-slate-900/80 border border-slate-800 rounded-xl p-2.5 min-w-[64px]">
                <span id="cd-seconds" class="text-2xl font-black text-white font-display leading-none">00</span>
                <span class="text-[8px] uppercase font-bold text-slate-500 tracking-wider mt-1.5">Seg</span>
              </div>
            </div>
          </div>

          <!-- Horarios del partido -->
          <div class="text-center md:text-right flex flex-col gap-1.5">
            <p id="hero-kickoff-estadio" class="text-sm text-slate-300 font-medium">
              Estadio: <strong class="text-white">--</strong>
            </p>
            <p id="hero-kickoff-user" class="text-sm text-slate-300 font-medium">
              Tu Hora: <strong class="text-amber-400">--</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAVEGACIÓN TABS -->
    <div class="flex border-b border-slate-800 gap-1 overflow-x-auto scrollbar-none">
      <button id="tab-btn-fixture" class="tab-btn active px-6 py-3.5 font-display font-bold text-sm border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-all duration-300">
        ⚽ Fixture y Resultados
      </button>
      <button id="tab-btn-groups" class="tab-btn px-6 py-3.5 font-display font-bold text-sm border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-all duration-300">
        📊 Grupos y Posiciones
      </button>
      <button id="tab-btn-stadiums" class="tab-btn px-6 py-3.5 font-display font-bold text-sm border-b-2 border-transparent text-slate-400 hover:text-slate-200 transition-all duration-300">
        🏟️ Estadios e Info
      </button>
    </div>

    <!-- PESTAÑA 1: FIXTURE -->
    <div id="tab-content-fixture" class="tab-content flex flex-col gap-6">
      
      <!-- Filtros -->
      <div class="bg-slate-950/20 backdrop-blur-md border border-slate-800/80 rounded-2xl p-5 flex flex-col gap-4">
        <div class="text-xs font-extrabold uppercase tracking-widest text-slate-400">
          🔍 Filtrar y Buscar Partidos
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <!-- Búsqueda -->
          <div class="flex flex-col gap-1.5">
            <label for="filter-search" class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Buscar selección</label>
            <input id="filter-search" type="text" placeholder="Ej: Argentina, México, Brasil..." class="bg-slate-900/60 border border-slate-800 text-white px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500/20 transition-all duration-300" />
          </div>

          <!-- Fase del torneo -->
          <div class="flex flex-col gap-1.5">
            <label for="filter-stage" class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Fase del Torneo</label>
            <select id="filter-stage" class="bg-slate-900/60 border border-slate-800 text-white px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:border-emerald-500 transition-all duration-300">
              <option value="all">Todas las Fases</option>
              <option value="group">Fase de Grupos</option>
              <option value="r32">Dieciseisavos de Final</option>
              <option value="r16">Octavos de Final</option>
              <option value="qf">Cuartos de Final</option>
              <option value="sf">Semifinales</option>
              <option value="third">Tercer Puesto</option>
              <option value="final">Final</option>
            </select>
          </div>

          <!-- Grupos (si es Fase de Grupos) -->
          <div class="flex flex-col gap-1.5">
            <label for="filter-group" class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Grupo</label>
            <select id="filter-group" class="bg-slate-900/60 border border-slate-800 text-white px-4 py-2.5 rounded-xl text-sm focus:outline-none focus:border-emerald-500 transition-all duration-300">
              <option value="all">Todos los Grupos</option>
              <option value="A">Grupo A</option>
              <option value="B">Grupo B</option>
              <option value="C">Grupo C</option>
              <option value="D">Grupo D</option>
              <option value="E">Grupo E</option>
              <option value="F">Grupo F</option>
              <option value="G">Grupo G</option>
              <option value="H">Grupo H</option>
              <option value="I">Grupo I</option>
              <option value="J">Grupo J</option>
              <option value="K">Grupo K</option>
              <option value="L">Grupo L</option>
            </select>
          </div>
        </div>

        <!-- Filtros Rápidos Checkboxes -->
        <div class="flex flex-wrap gap-5 pt-3 border-t border-slate-800/60">
          <label class="flex items-center gap-2.5 text-[10px] font-bold text-slate-400 uppercase tracking-wider cursor-pointer select-none">
            <input id="filter-check-live" type="checkbox" class="w-4 h-4 rounded border-slate-800 bg-slate-900 text-emerald-600 focus:ring-emerald-500/20 accent-emerald-500 cursor-pointer" />
            Solo En Vivo / Terminados
          </label>
          <label class="flex items-center gap-2.5 text-[10px] font-bold text-slate-400 uppercase tracking-wider cursor-pointer select-none">
            <input id="filter-check-favorites" type="checkbox" class="w-4 h-4 rounded border-slate-800 bg-slate-900 text-emerald-600 focus:ring-emerald-500/20 accent-emerald-500 cursor-pointer" />
            Favoritos de América
          </label>
        </div>
      </div>

      <!-- Timeline partidos -->
      <div class="flex flex-col gap-4">
        <div class="flex justify-between items-center">
          <h2 class="text-lg md:text-xl font-bold font-display text-white">
            📅 Partidos <span id="matches-count" class="text-xs bg-emerald-600/20 text-emerald-400 px-2 py-0.5 rounded-full font-extrabold border border-emerald-500/10 ml-2">104</span>
          </h2>
        </div>

        <!-- Matches list grid -->
        <div id="matches-grid" class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <!-- Skeletons renderizados inicialmente en el servidor -->
          {Array.from({ length: 6 }).map((_, i) => (
            <div class="animate-pulse bg-slate-900/20 border border-slate-800/80 rounded-2xl p-4 shadow-lg flex flex-col justify-between gap-4 h-[130px]">
              <div class="flex justify-between items-center border-b border-slate-800/40 pb-2">
                <div class="h-2.5 w-24 bg-slate-800 rounded"></div>
                <div class="h-3 w-12 bg-slate-800 rounded"></div>
              </div>
              <div class="flex justify-between items-center py-1.5 gap-3">
                <div class="flex items-center gap-2.5 w-[42%] justify-start">
                  <div class="w-8 h-5.5 bg-slate-800 rounded shadow"></div>
                  <div class="h-3.5 w-16 bg-slate-800 rounded"></div>
                </div>
                <div class="h-7 w-14 bg-slate-800 rounded-lg"></div>
                <div class="flex items-center gap-2.5 w-[42%] justify-end">
                  <div class="h-3.5 w-16 bg-slate-800 rounded"></div>
                  <div class="w-8 h-5.5 bg-slate-800 rounded shadow"></div>
                </div>
              </div>
              <div class="flex justify-between items-center pt-2 border-t border-slate-800/40">
                <div class="h-2 w-20 bg-slate-800 rounded"></div>
                <div class="h-2 w-24 bg-slate-800 rounded"></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Empty state -->
        <div id="matches-empty" class="hidden bg-slate-950/20 border border-slate-800 rounded-2xl p-12 text-center flex flex-col items-center gap-3">
          <span class="text-3xl">🔍</span>
          <div class="font-bold text-slate-200">No se encontraron partidos</div>
          <p class="text-xs text-slate-400">Intenta reajustar los filtros.</p>
        </div>
      </div>
    </div>

    <!-- PESTAÑA 2: GRUPOS -->
    <div id="tab-content-groups" class="tab-content hidden">
      <h2 class="sr-only">Grupos y Posiciones</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="groups-grid">
        <!-- Dinámico -->
      </div>
    </div>

    <!-- PESTAÑA 3: ESTADIOS -->
    <div id="tab-content-stadiums" class="tab-content hidden">
      <h2 class="sr-only">Estadios e Información</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="stadiums-grid">
        <!-- Dinámico -->
      </div>
    </div>
  </main>
</Layout>

<style>
  .tab-btn.active {
    color: #fbbf24 !important; /* Gold text */
    border-bottom-color: #fbbf24 !important; /* Gold border */
  }
  .hidden {
    display: none !important;
  }
</style>

<script>
  const appDataEl = document.getElementById('app-data');
  if (!appDataEl) throw new Error("App data elements not found");
  
  const initialMatches = JSON.parse(appDataEl.getAttribute('data-matches') || '[]');
  const initialTeams = JSON.parse(appDataEl.getAttribute('data-teams') || '[]');
  const initialStadiums = JSON.parse(appDataEl.getAttribute('data-stadiums') || '[]');
  const teamTranslations = JSON.parse(appDataEl.getAttribute('data-translations') || '{}');
  const stageTranslations = JSON.parse(appDataEl.getAttribute('data-stages') || '{}');
  const stadiumInfo = JSON.parse(appDataEl.getAttribute('data-stadium-info') || '{}');

  let matches = [...initialMatches];
  let teams = [...initialTeams];
  let stadiums = [...initialStadiums];

  // Función de sanitización para prevenir XSS
  function sanitize(str: any): string {
    if (str === null || str === undefined) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#x27;')
      .replace(/\//g, '&#x2F;');
  }
  
  // Header clock
  setInterval(() => {
    const clockEl = document.getElementById('user-local-clock');
    if (clockEl) {
      clockEl.textContent = new Date().toLocaleTimeString('es-ES');
    }
  }, 1000);

  // Tab switching
  const tabs = [
    { btn: 'tab-btn-fixture', content: 'tab-content-fixture' },
    { btn: 'tab-btn-groups', content: 'tab-content-groups' },
    { btn: 'tab-btn-stadiums', content: 'tab-content-stadiums' }
  ];

  tabs.forEach(tab => {
    const btnEl = document.getElementById(tab.btn);
    if (btnEl) {
      btnEl.addEventListener('click', () => {
        tabs.forEach(t => {
          document.getElementById(t.btn)?.classList.remove('active');
          document.getElementById(t.content)?.classList.add('hidden');
