  function renderGroupsAndPositions() {
    const gridEl = document.getElementById('groups-grid');
    if (!gridEl) return;
    
    gridEl.innerHTML = '';
    
    const groupsMap: Record<string, any[]> = {};
    const alphabet = "ABCDEFGHIJKL".split("");
    alphabet.forEach(letter => {
      groupsMap[letter] = [];
    });
    
    teams.forEach(t => {
      if (t.groups && groupsMap[t.groups]) {
        groupsMap[t.groups].push({
          id: t.id,
          name: getTeamName(t.name_en),
          flag: t.flag,
          iso2: t.iso2,
          pj: 0, w: 0, d: 0, l: 0, gf: 0, ga: 0, gd: 0, pts: 0
        });
      }
    });
    
    matches.forEach(m => {
      if (m.type === 'group' && (m.finished === "TRUE" || m.time_elapsed !== "notstarted")) {
        const homeScore = parseInt(m.home_score) || 0;
        const awayScore = parseInt(m.away_score) || 0;
        const groupLetter = m.group;
        
        const groupTeams = groupsMap[groupLetter];
        if (groupTeams) {
          const homeTeamObj = groupTeams.find(t => t.id === m.home_team_id);
          const awayTeamObj = groupTeams.find(t => t.id === m.away_team_id);
          
          if (homeTeamObj && awayTeamObj) {
            homeTeamObj.pj += 1;
            awayTeamObj.pj += 1;
            homeTeamObj.gf += homeScore;
            homeTeamObj.ga += awayScore;
            awayTeamObj.gf += awayScore;
            awayTeamObj.ga += homeScore;
            homeTeamObj.gd = homeTeamObj.gf - homeTeamObj.ga;
            awayTeamObj.gd = awayTeamObj.gf - awayTeamObj.ga;
            
            if (homeScore > awayScore) {
              homeTeamObj.w += 1;
              homeTeamObj.pts += 3;
              awayTeamObj.l += 1;
            } else if (homeScore < awayScore) {
              awayTeamObj.w += 1;
              awayTeamObj.pts += 3;
              homeTeamObj.l += 1;
            } else {
              homeTeamObj.d += 1;
              homeTeamObj.pts += 1;
              awayTeamObj.d += 1;
              awayTeamObj.pts += 1;
            }
          }
        }
      }
    });
    
    alphabet.forEach(groupLetter => {
      const groupTeams = groupsMap[groupLetter];
      groupTeams.sort((a, b) => {
        if (b.pts !== a.pts) return b.pts - a.pts;
        if (b.gd !== a.gd) return b.gd - a.gd;
        return b.gf - a.gf;
      });
      
      const rowsHtml = groupTeams.map((t, idx) => `
        <tr class="border-b border-slate-900/40 text-xs text-slate-300">
          <td class="py-2.5 font-bold text-center text-slate-500 w-6">${idx + 1}</td>
          <td class="py-2.5 flex items-center gap-2 font-semibold text-slate-100">
            <img src="https://flagcdn.com/w80/${t.iso2.toLowerCase()}.png" class="w-5 h-3.5 object-cover rounded shadow border border-slate-950" alt="" />
            <span class="truncate max-w-[100px]">${sanitize(t.name)}</span>
          </td>
          <td class="py-2.5 text-center font-medium">${sanitize(t.pj)}</td>
          <td class="py-2.5 text-center font-medium">${sanitize(t.w)}</td>
          <td class="py-2.5 text-center font-medium">${sanitize(t.d)}</td>
          <td class="py-2.5 text-center font-medium">${sanitize(t.l)}</td>
          <td class="py-2.5 text-center font-bold ${t.gd > 0 ? 'text-emerald-400' : (t.gd < 0 ? 'text-red-400' : '')}">${t.gd > 0 ? '+' + sanitize(t.gd) : sanitize(t.gd)}</td>
          <td class="py-2.5 text-center font-black text-amber-400">${sanitize(t.pts)}</td>
        </tr>
      `).join('');
      
      const groupCardHtml = `
        <div class="bg-slate-900/40 backdrop-blur-sm border border-slate-800/80 rounded-2xl p-5 flex flex-col gap-3 shadow-lg">
          <div class="flex justify-between items-center border-b border-slate-800 pb-2">
            <h3 class="text-sm font-black text-white font-display uppercase tracking-tight">
              GRUPO <span class="text-amber-400">${sanitize(groupLetter)}</span>
            </h3>
            <span class="text-[9px] font-bold text-slate-500 uppercase tracking-wider bg-slate-950 border border-slate-800/80 px-2 py-0.5 rounded-full">Fase de Grupos</span>
          </div>
          
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="text-[9px] uppercase font-bold text-slate-500 border-b border-slate-800">
                <th class="py-1.5 text-center w-6">#</th>
                <th class="py-1.5">Equipo</th>
                <th class="py-1.5 text-center">PJ</th>
                <th class="py-1.5 text-center">PG</th>
                <th class="py-1.5 text-center">PE</th>
                <th class="py-1.5 text-center">PP</th>
                <th class="py-1.5 text-center">DG</th>
                <th class="py-1.5 text-center text-amber-400">PTS</th>
              </tr>
            </thead>
            <tbody>
              ${rowsHtml}
            </tbody>
          </table>
        </div>
      `;
      
      gridEl.insertAdjacentHTML('beforeend', groupCardHtml);
    });
  }

  function renderStadiums() {
    const gridEl = document.getElementById('stadiums-grid');
    if (!gridEl) return;
    
    gridEl.innerHTML = '';
    
    stadiums.forEach(s => {
      const sInfo = stadiumInfo[s.id] || { name: s.name_en, city: s.city_en, country: s.country_en };
      const countryFlagCode = s.country_en === 'United States' ? 'us' : (s.country_en === 'Mexico' || s.country_en === 'México' ? 'mx' : 'ca');
      
      const cardHtml = `
        <div class="bg-slate-900/40 backdrop-blur-sm border border-slate-800/80 rounded-2xl p-4 shadow-lg flex flex-col justify-between gap-3.5 transition-all duration-300 hover:border-slate-700/80">
          <div class="flex justify-between items-center border-b border-slate-850 pb-2 text-[9px] text-slate-500 font-bold uppercase tracking-wider">
            <span class="flex items-center gap-1.5">
              <img src="https://flagcdn.com/w80/${countryFlagCode}.png" class="w-4.5 h-3 object-cover rounded-sm border border-slate-950" alt="" />
              ${sanitize(sInfo.country)}
            </span>
            <span>👥 ${sanitize(s.capacity.toLocaleString('es-ES'))}</span>
          </div>
          
          <div class="flex flex-col gap-0.5">
            <h3 class="text-sm font-bold text-slate-100 truncate tracking-tight" title="${sanitize(s.name_en)}">
              ${sanitize(s.name_en)}
            </h3>
            <p class="text-xs text-slate-400 font-medium">
              📍 ${sanitize(sInfo.city)}
            </p>
          </div>
          
          <div class="text-[9px] uppercase font-bold text-slate-400 bg-slate-950 border border-slate-855 px-2 py-1.5 rounded flex justify-between tracking-wide">
            <span>Región: ${sanitize(s.region)}</span>
            <span>UTC ${sInfo.offset >= 0 ? '+' + sanitize(sInfo.offset) : sanitize(sInfo.offset)}</span>
          </div>
        </div>
      `;
      
      gridEl.insertAdjacentHTML('beforeend', cardHtml);
    });
  }

  document.getElementById('filter-search')?.addEventListener('input', renderMatchesList);
  document.getElementById('filter-stage')?.addEventListener('change', renderMatchesList);
  document.getElementById('filter-group')?.addEventListener('change', renderMatchesList);
  document.getElementById('filter-check-live')?.addEventListener('change', renderMatchesList);
  document.getElementById('filter-check-favorites')?.addEventListener('change', renderMatchesList);

  async function fetchLiveUpdates() {
    const apiStatusDot = document.getElementById('api-status-dot');
    const apiStatusText = document.getElementById('api-status-text');
    
    try {
      const response = await fetch('/api/games');
      if (!response.ok) throw new Error("API Response not OK");
      
      const data = await response.json();
      
      if (data && data.games && Array.isArray(data.games)) {
        matches = data.games;
        
        if (apiStatusDot) {
          apiStatusDot.className = "w-2.5 h-2.5 rounded-full bg-emerald-500";
        }
        if (apiStatusText) {
          apiStatusText.textContent = "Conectado (En Vivo)";
          apiStatusText.className = "text-emerald-400";
        }
        
        renderHero();
        renderMatchesList();
        renderGroupsAndPositions();
      }
    } catch (err) {
      console.warn("Error fetching live data, falling back to local database:", err);
      
      if (apiStatusDot) {
        apiStatusDot.className = "w-2.5 h-2.5 rounded-full bg-blue-500";
      }
      if (apiStatusText) {
        apiStatusText.textContent = "Modo Respaldo (Local)";
        apiStatusText.className = "text-blue-400";
      }
    }
  }

  renderHero();
  renderMatchesList();
  renderGroupsAndPositions();
  renderStadiums();
  
  fetchLiveUpdates();
  setInterval(fetchLiveUpdates, 30000);
</script>
