  "5": { name: "NRG Stadium", city: "Houston", country: "Estados Unidos", timezone: "America/Chicago", offset: -5 },
  "6": { name: "GEHA Field at Arrowhead Stadium", city: "Kansas City", country: "Estados Unidos", timezone: "America/Chicago", offset: -5 },
  "7": { name: "Mercedes-Benz Stadium", city: "Atlanta", country: "Estados Unidos", timezone: "America/New_York", offset: -4 },
  "8": { name: "Hard Rock Stadium", city: "Miami Gardens", country: "Estados Unidos", timezone: "America/New_York", offset: -4 },
