        btnEl.classList.add('active');
        document.getElementById(tab.content)?.classList.remove('hidden');
      });
    }
  });

  function getTeamName(englishName: string): string {
    return teamTranslations[englishName] || englishName;
  }

  function getMatchDate(localDateStr: string, stadiumId: string): Date {
    const info = stadiumInfo[stadiumId] || { offset: -4 };
    const offset = info.offset;
    
    const [datePart, timePart] = localDateStr.split(' ');
    const [month, day, year] = datePart.split('/');
    const [hour, minute] = timePart.split(':');
    
    const absOffset = Math.abs(offset);
    const sign = offset >= 0 ? '+' : '-';
    const formattedOffset = `${sign}${String(absOffset).padStart(2, '0')}:00`;
    
    const isoString = `${year}-${month}-${day}T${hour}:${minute}:00${formattedOffset}`;
    return new Date(isoString);
  }

  function formatMatchDate(date: Date): { day: string, time: string } {
    const optionsDay: Intl.DateTimeFormatOptions = { weekday: 'long', day: 'numeric', month: 'short' };
    const optionsTime: Intl.DateTimeFormatOptions = { hour: '2-digit', minute: '2-digit' };
    
    const dayStr = date.toLocaleDateString('es-ES', optionsDay);
    const timeStr = date.toLocaleTimeString('es-ES', optionsTime);
    
    return {
      day: dayStr.charAt(0).toUpperCase() + dayStr.slice(1),
      time: timeStr
    };
  }

  // Calcular el tiempo transcurrido del partido si la API retorna "live"
  function getLiveTimeText(match: any, isLongFormat: boolean): string {
    const raw = match.time_elapsed;
    if (!raw || raw === 'notstarted') return '';
    
    if (raw === 'halfTime') {
      return 'Entretiempo';
    }
    
    if (!isNaN(Number(raw))) {
      return isLongFormat ? `Minuto ${raw}` : `Min. ${raw}`;
    }
    
    // Si dice "live" o "LIVE" (o cualquier otro valor en vivo no numérico)
    return isLongFormat ? "En Vivo" : "";
  }

  // Limpiar texto de goleadores retornado por la API
  function cleanScorers(scorersStr: string): string {
    if (!scorersStr || scorersStr === 'null' || scorersStr === '') return '';
    
    let cleaned = scorersStr.trim();
    if (cleaned.startsWith('{') && cleaned.endsWith('}')) {
      cleaned = cleaned.slice(1, -1).trim();
    }
    if (cleaned.startsWith('[') && cleaned.endsWith(']')) {
      cleaned = cleaned.slice(1, -1).trim();
    }
    
    // Quitar comillas al inicio y final
    cleaned = cleaned.replace(/^["'“”«»]+|["'“”«»]+$/g, '').trim();
    
    // Quitar todas las comillas dobles y comillas tipográficas internas
    cleaned = cleaned.replace(/["“”]/g, '').trim();
    
    return cleaned;
  }

  let countdownInterval: number | undefined;
  function updateCountdown(targetDate: Date) {
    if (countdownInterval) clearInterval(countdownInterval);
    
    const daysEl = document.getElementById('cd-days');
    const hoursEl = document.getElementById('cd-hours');
    const minsEl = document.getElementById('cd-minutes');
    const secsEl = document.getElementById('cd-seconds');
    
    function run() {
      const now = new Date().getTime();
      const distance = targetDate.getTime() - now;
      
      if (distance < 0) {
        if (daysEl) daysEl.textContent = '00';
        if (hoursEl) hoursEl.textContent = '00';
        if (minsEl) minsEl.textContent = '00';
        if (secsEl) secsEl.textContent = '00';
        clearInterval(countdownInterval);
        return;
      }
      
      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);
      
      if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
      if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
      if (minsEl) minsEl.textContent = String(minutes).padStart(2, '0');
      if (secsEl) secsEl.textContent = String(seconds).padStart(2, '0');
    }
    
    run();
    countdownInterval = setInterval(run, 1000) as unknown as number;
  }

