---
import Layout from "../layouts/Layout.astro";
import SocialPill from "../components/SocialPill.astro";
import HeroTitle from "../components/HeroTitle.astro";
import LinkedInIcon from "../components/icons/LinkedIn.astro";
import GithubIcon from "../components/icons/Github.astro";
import GmailIcon from "../components/icons/Gmail.astro";
import SectionContainer from "../components/SectionContainer.astro";
import Experiencie from "../components/Experiencie.astro";
import WorkAnimatedIcon from "../components/icons/WorkAnimated.astro";
import TechAnimatedIcon from "../components/icons/TechAnimated.astro";
import ProjectsAnimatedIcon from "../components/icons/ProjectsAnimated.astro";
import Projects from "../components/Projects.astro";
import About from "../components/About.astro";
import AboutTypingIcon from "../components/icons/AboutTyping.astro";
import TechStack from "../components/TechStack.astro";
import FeaturedProject from "../components/FeaturedProject.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title="Portfolio de Guido Juliano Web Developer">
  <main class="px-4">
    <div class="flex items-center justify-center h-screen">
      <SectionContainer>
        <h1
          class="text-3xl font-bold text-purple-200 flex flex-row justify-center md:justify-start gap-x-4 pb-8 md:pb-10 text-center md:text-left md:text-5xl"
        >
          <HeroTitle text={t("home.title")} />
          <!-- <a
            href="https://www.linkedin.com/in/guidojuliano/"
            target="_blank"
            rel="noopener"
            class="flex justify-center items-center"
          >
            <Badge class="bg-green-300 text-green-800">Open to work</Badge>
          </a> -->
        </h1>

        <h2 class="text-lg opacity-80 text-wrap text-center md:text-left md:text-2xl">
          <span class="font-semibold text-yellow-200/90">{t("home.work")}</span>

          <br />
          <span class="text-blue-200/90">{t("home.description")}</span>
        </h2>

        <div class="mt-6 flex flex-wrap gap-3 justify-center md:justify-start">
          <a
            href="#projects"
            class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-yellow-200/20 px-5 py-2 text-sm font-semibold text-yellow-100 hover:bg-yellow-200/30 hover:scale-105 transition"
          >
            {t("home.ctaProjects")}
          </a>
          <a
            href="https://drive.google.com/file/d/1okEBXEyITc4DjXCdDi1gu415SSYADVIw/view?usp=sharing"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-5 py-2 text-sm font-semibold text-white/90 hover:bg-white/10 hover:scale-105 transition"
          >
            {t("home.ctaCv")}
          </a>
        </div>

        <ul class="flex gap-3 py-3 flex-wrap justify-center md:justify-start">
          <li>
            <SocialPill
              href="https://www.linkedin.com/in/guidojuliano/"
              class="text-purple-200/90 p-0 w-12 h-12 md:w-auto md:h-auto md:px-3 md:py-2.5"
            >
              <LinkedInIcon class="size-5 md:size-6" />
              <span class="hidden md:inline">LinkedIn</span>
            </SocialPill>
          </li>
          <li>
            <SocialPill
              href="https://github.com/guidojuliano"
              class="text-purple-200/90 p-0 w-12 h-12 md:w-auto md:h-auto md:px-3 md:py-2.5"
            >
              <GithubIcon class="size-5 md:size-6" />
              <span class="hidden md:inline">Github</span>
            </SocialPill>
          </li>
          <li>
            <SocialPill
              href="mailto:guidojulianou@gmail.com"
              class="text-purple-200/90 p-0 w-12 h-12 md:w-auto md:h-auto md:px-3 md:py-2.5"
            >
              <GmailIcon class="size-5 md:size-6" />
              <span class="hidden md:inline">guidojulianou@gmail.com</span>
            </SocialPill>
          </li>
        </ul>
      </SectionContainer>
    </div>
    <SectionContainer id="about" class="md:pt-80 pt-40">
      <h2
        class="text-4xl text-purple-200 font-semibold mb-8 flex gap-x-3 items-center"
      >
        <AboutTypingIcon class="size-11 md:size-12" />
        {t("about.title")}
      </h2>
      <About />
    </SectionContainer>
    <SectionContainer id="experience" class="md:pt-80 pt-40">
      <h2
        class="text-4xl text-purple-200 font-semibold mb-8 flex gap-x-3 items-center"
      >
        <WorkAnimatedIcon class="size-11 md:size-12" />
        {t("experience.title")}
      </h2>
      <Experiencie />
    </SectionContainer>
    <SectionContainer id="tech" class="md:pt-60 pt-40">
      <h2
        class="text-4xl text-purple-200 font-semibold mb-6 flex gap-x-3 items-center"
      >
        <TechAnimatedIcon class="size-11 md:size-12" />
        {t("tech.title")}
      </h2>
      <TechStack />
    </SectionContainer>
    <SectionContainer id="projects" class="md:pt-48 pt-32">
      <h2
        class="text-4xl text-purple-200 font-semibold mb-6 flex gap-x-3 items-center"
      >
        <ProjectsAnimatedIcon class="size-11 md:size-12" />
        {t("projects.title")}
      </h2>
      <Projects />
      <h3 class="text-2xl text-purple-200/90 font-semibold mt-12 mb-5 flex gap-x-2 items-center">
        <ProjectsAnimatedIcon class="size-8" />
        {t("featured.title")}
      </h3>
      <FeaturedProject />
    </SectionContainer>
  </main>
</Layout>
